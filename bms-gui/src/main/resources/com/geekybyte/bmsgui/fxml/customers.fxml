<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.geekybyte.bmsgui.controller.CustomersController"
      spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Customers" styleClass="page-title"/>
        <VBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search by name, email, or national ID" prefWidth="280"
                   onAction="#onSearch"/>
        <Button text="Search" styleClass="button-secondary" onAction="#onSearch"/>
        <Button text="+ New Customer" styleClass="button-primary" onAction="#onNew"/>
    </HBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="180"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
                <TableColumn fx:id="colNationalId" text="National ID" prefWidth="130"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="220"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="prevButton" text="◀ Prev" styleClass="button-secondary" onAction="#onPrevPage"/>
            <Label fx:id="pageLabel" text="Page 1 of 1"/>
            <Button fx:id="nextButton" text="Next ▶" styleClass="button-secondary" onAction="#onNextPage"/>
        </HBox>
    </VBox>
</VBox>
